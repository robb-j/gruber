{
	"$comment": "This is for node-based TypeScript checking only",
	"compilerOptions": {
		"target": "ESNext",
		"module": "Preserve",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noEmit": true
	},
	"include": [
		"browser",
		"bundle",
		"config",
		"core",
		"examples/node-fs-migrator",
		"examples/node",
		"http",
		"node",
		"postgres",
		"scripts",
		"testing"
	]
}
